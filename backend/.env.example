# Copy to .env and fill in. .env is gitignored; never commit your real key.

# Anthropic credential. The SDK also accepts ANTHROPIC_AUTH_TOKEN or an
# `ant auth login` profile instead of a raw key.
ANTHROPIC_API_KEY=sk-ant-...

# Compliant Wikimedia User-Agent (identify the tool + a monitored contact).
USER_AGENT="WikiAfCReviewer/1.0 (https://en.wikipedia.org/wiki/User:Ordiopside; or@diopside.ai) python-requests"

# Optional overrides:
# ALLOWED_ORIGIN=https://en.wikipedia.org
# PORT=5000

# Model tuning (defaults shown). Stage 1 = search + notability judgment (quality);
# stage 2 = mechanical JSON conversion. A/B without code edits:
# ANALYZE_MODEL=claude-opus-4-8     # judgment model; try claude-sonnet-4-6 to halve cost
# ANALYZE_EFFORT=high               # try "medium" to cut the web-search turn's cost/latency
# CONVERT_MODEL=claude-haiku-4-5    # restructuring only; keep small
